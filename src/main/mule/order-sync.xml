<?xml version="1.0" encoding="UTF-8"?>

<mule xmlns:file="http://www.mulesoft.org/schema/mule/file"
	xmlns:ee="http://www.mulesoft.org/schema/mule/ee/core"
	xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
	xmlns="http://www.mulesoft.org/schema/mule/core"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="
http://www.mulesoft.org/schema/mule/file http://www.mulesoft.org/schema/mule/file/current/mule-file.xsd
		http://www.mulesoft.org/schema/mule/core
		http://www.mulesoft.org/schema/mule/core/current/mule.xsd
		http://www.mulesoft.org/schema/mule/ee/core
		http://www.mulesoft.org/schema/mule/ee/core/current/mule-ee.xsd
		http://www.mulesoft.org/schema/mule/file
		http://www.mulesoft.org/schema/mule/file/current/mule-file.xsd">

	<sub-flow name="process-order-sync-subflow">
		<set-variable doc:name="Set sync status"
			variableName="syncStatus" value="#[payload.status as String]" />
		<set-variable doc:name="Set page size"
			variableName="pageSize"
			value="#[(payload.pageSize default 20) as Number]" />

		<logger doc:name="Log synchronization start" level="INFO"
			message="#[write({
                message: 'Confirmed orders synchronization started',
                correlationId: correlationId,
                status: vars.syncStatus,
                pageSize: vars.pageSize
            }, 'application/json')]" />

		<flow-ref doc:name="Authenticate with Cham Orders API"
			name="authenticate-cham-orders-subflow" />
		<flow-ref doc:name="Retrieve all confirmed orders"
			name="retrieve-all-confirmed-orders-subflow" />

		<ee:transform doc:name="Validate confirmed orders">
			<ee:variables>
				<ee:set-variable variableName="hasInvalidOrders"
					resource="dw/has-invalid-orders.dwl" />
			</ee:variables>
		</ee:transform>

		<choice doc:name="Reject invalid confirmed orders">
			<when expression="#[vars.hasInvalidOrders]">
				<raise-error type="CHAM_ORDERS:INVALID_RESPONSE"
					description="Cham Orders API returned an order that cannot be mapped to the canonical model." />
			</when>
		</choice>
		<remove-variable doc:name="Remove validation result"
			variableName="hasInvalidOrders" />

		<set-variable doc:name="Set orders read"
			variableName="ordersRead"
			value="#[sizeOf(vars.confirmedOrders default [])]" />
		<set-variable doc:name="Set generation timestamp"
			variableName="generatedAt" value="#[now()]" />
		<set-variable doc:name="Set output file name"
			variableName="outputFile"
			value="#['confirmed-orders-' ++ (vars.generatedAt as String {format: 'yyyyMMdd-HHmmss-SSS'}) ++ '.json']" />

		<ee:transform
			doc:name="Transform orders to canonical model">
			<ee:message>
				<ee:set-payload resource="dw/orders-to-canonical.dwl" />
			</ee:message>
		</ee:transform>

		<file:write doc:name="Write canonical orders file"
			config-ref="cham-orders-file-config"
			path="#[Mule::p('output.directory') ++ '/' ++ vars.outputFile]"
			createParentDirectories="true" mode="CREATE_NEW">
			<file:content><![CDATA[#[output application/json indent=true
---
payload]]]></file:content>
		</file:write>

		<logger doc:name="Log synchronization completion" level="INFO"
			message="#[write({
                message: 'Confirmed orders synchronization completed',
                correlationId: correlationId,
                ordersRead: vars.ordersRead,
                ordersExported: vars.ordersRead,
                outputFile: vars.outputFile
            }, 'application/json')]" />

		<remove-variable doc:name="Remove confirmed orders"
			variableName="confirmedOrders" />

		<ee:transform doc:name="Build order sync response">
			<ee:message>
				<ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
    correlationId: correlationId,
    status: "COMPLETED",
    ordersRead: vars.ordersRead,
    ordersExported: vars.ordersRead,
    outputFile: vars.outputFile
}]]></ee:set-payload>
			</ee:message>
		</ee:transform>
	</sub-flow>
</mule>
